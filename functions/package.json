{
  "name": "autohirebot-functions",
  "description": "AutoHireBot Cloud Functions with ZeptoMail",
  "version": "4.0.0",
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "test": "mocha test/**/*.test.js --timeout 10000",
    "serve": "firebase emulators:start --only functions",
