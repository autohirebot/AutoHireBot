    "node-fetch": "^2.7.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "firebase-functions-test": "^3.1.0",
    "mocha": "^10.8.2"
  },
  "private": true
}
